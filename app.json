{
  "expo": {
    "name": "morning",
    "slug": "morning",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "말씀하신 알람 시간을 인식하기 위해 음성 인식 권한이 필요해요.",
        "NSMicrophoneUsageDescription": "아침 할일 안내 및 음성으로 알람 시간을 설정하기 위해 마이크 접근 권한이 필요해요."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f1a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "REQUEST_INSTALL_PACKAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.morning"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "buildNumber": 0
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "아침 할일 안내 및 음성으로 알람 시간을 설정하기 위해 마이크 접근 권한이 필요해요.",
          "speechRecognitionPermission": "말씀하신 알람 시간을 인식하기 위해 음성 인식 권한이 필요해요."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#818cf8"
        }
      ]
    ]
  }
}
